# Contact form email delivery (Resend — https://resend.com)
# Put real values in .env.local (gitignored). Set the same vars in your host
# (Netlify/Vercel) for production.

# Required: your Resend API key
RESEND_API_KEY=

# Where inquiries are delivered. Defaults to SITE.email (hello@slateandcode.studio).
CONTACT_TO=hello@slateandcode.studio

# Verified sender. Until slateandcode.studio is verified in Resend, use the
# test sender below. After verifying the domain, switch to something like:
#   CONTACT_FROM="Slate & Code <inquiries@slateandcode.studio>"
CONTACT_FROM="Slate & Code <onboarding@resend.dev>"
